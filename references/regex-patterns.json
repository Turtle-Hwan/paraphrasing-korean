{
  "version": 1,
  "note": "정규식은 '후보 힌트'일 뿐 처방이 아니다. scan.py 가 워크시트의 각 문장에 의심 규칙 ID를 힌트로 달아 주지만, 실제 윤문은 에이전트가 문장 단위로 판단해 수행한다. 오탐(false positive)이 있을 수 있으니 힌트가 없다고 윤문 대상이 아닌 것도, 힌트가 있다고 반드시 고쳐야 하는 것도 아니다. 기여자는 여기 항목을 늘려 가면 된다(아래 패턴은 한국어 조사 변이 때문에 느슨하게 잡는다).",
  "patterns": [
    { "id": "S-3", "name": "이중피동", "rulebook": "sentence", "regex": "(나뉘어진|잊혀지|보여지|모아지|불려지|벌려진|쓰여지|닫혀지|놓여지)" },
    { "id": "S-4", "name": "-에 의해/의한", "rulebook": "sentence", "regex": "에\\s*의(해|한)" },
    { "id": "S-5", "name": "대한/대해", "rulebook": "sentence", "regex": "에\\s*(대한|대해서?)" },
    { "id": "S-6", "name": "-로부터", "rulebook": "sentence", "regex": "(으)?로부터" },
    { "id": "S-9", "name": "-수 있", "rulebook": "sentence", "regex": "수\\s*(있|없)" },
    { "id": "S-10", "name": "-기 시작하다", "rulebook": "sentence", "regex": "기\\s*시작(했|한|하)" },
    { "id": "S-11", "name": "-시키다", "rulebook": "sentence", "regex": "[가-힣]시(키|켜)" },
    { "id": "T-2", "name": "가지고 있다", "rulebook": "trans", "regex": "가지(고\\s*있|는)" },
    { "id": "T-3", "name": "-로 인", "rulebook": "trans", "regex": "(으)?로\\s*인(해|하여|한)" },
    { "id": "T-4", "name": "-에 대하여/관하여", "rulebook": "trans", "regex": "에\\s*(대하여|관하여|관한|관해서?)" },
    { "id": "T-6", "name": "-을 통해", "rulebook": "trans", "regex": "통(해|하여|한)\\s" },
    { "id": "T-9", "name": "위치하다", "rulebook": "trans", "regex": "에\\s*위치" },
    { "id": "T-9b", "name": "-에도 불구하고", "rulebook": "trans", "regex": "에도\\s*불구하고" },
    { "id": "T-9c", "name": "-을 필요로 한다", "rulebook": "trans", "regex": "필요로\\s*(한다|하는|했)" },
    { "id": "AI-2", "name": "결말 공식", "rulebook": "ai", "regex": "(시사하는\\s*바가\\s*크|^결국,|본질적으로)" },
    { "id": "AI-3", "name": "hype 어휘", "rulebook": "ai", "regex": "(혁신적|획기적|놀라운|강력한|필수적|중요한\\s*역할)" },
    { "id": "AI-8", "name": "형식명사 것이다", "rulebook": "ai", "regex": "(라는\\s*것이다|라는\\s*점이다|라는\\s*뜻이다)" }
  ]
}
